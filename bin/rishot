#!/bin/sh
# rishot - Wayland screenshot + annotation overlay (Quickshell).
# Launches the overlay on the current output set. Bind this command to a key
# in your compositor config (see README). Region mode also lets you click a
# single window to grab it.

set -eu

usage() {
	cat <<'EOF'
rishot - screenshot + annotate

usage: rishot [mode]

modes:
  (none), region   drag a region, or click a window to grab it (default)
  monitor          click a monitor to grab the whole output

options:
  -h, --help       show this help

env:
  RISHOT_CONFIG_DIR  override the Quickshell config dir (must hold shell.qml)
  RISHOT_UPLOAD      override the upload endpoint (https form-post target)
  RISHOT_SAVEDIR     override the auto-save directory
  RISHOT_KEYBIND_FILE  write the in-app rebind here instead of autodetecting
EOF
}

mode=region
case "${1:-}" in
	monitor | --monitor | -m) mode=monitor ;;
	region | --region | -r | "") mode=region ;;
	-h | --help) usage; exit 0 ;;
	*) printf 'rishot: unknown argument: %s\n' "$1" >&2; usage >&2; exit 2 ;;
esac

dir="${RISHOT_CONFIG_DIR:-}"
if [ -z "$dir" ]; then
	self=$(dirname "$(readlink -f "$0")")
	# The src/ beside this launcher comes first so a checkout or a freshly pulled
	# copy always runs its own code instead of a stale shared install; the install
	# paths are only a fallback. A normal install resolves $self/../src to the same
	# place, so this changes nothing there.
	for c in \
		"$self/../src" \
		"${HOME:-}/.local/share/rishot/src" \
		/usr/share/rishot/src \
		/usr/lib/rishot/src; do
		if [ -f "$c/shell.qml" ]; then dir="$c"; break; fi
	done
fi

if [ -z "$dir" ] || [ ! -f "$dir/shell.qml" ]; then
	echo "rishot: could not locate the config dir (set RISHOT_CONFIG_DIR)" >&2
	exit 1
fi

command -v qs >/dev/null 2>&1 || {
	echo "rishot: 'qs' (quickshell) not found in PATH" >&2
	exit 1
}

# Single instance: a second press while the overlay is up is a no-op. The lock
# is held on fd 9 for the lifetime of qs; clipboard daemons that qs spawns close
# fd 9 (see shell.qml) so a backgrounded wl-copy cannot pin the lock after exit.
# Keep the lock in a user-owned dir: XDG_RUNTIME_DIR is per-user 0700, and the
# ~/.cache fallback avoids the world-writable /tmp symlink-follow on shared boxes.
rundir="${XDG_RUNTIME_DIR:-$HOME/.cache}"
mkdir -p "$rundir" 2>/dev/null || rundir="/tmp"
lock="$rundir/rishot.lock"
exec 9>"$lock"
flock -n 9 || { echo "rishot: already running" >&2; exit 0; }

# On Hyprland, freeze the desktop before Quickshell maps its layer-shell
# windows. Mapping the overlay first transfers pointer focus away from the
# application underneath, which closes hovered tooltips and menus before
# ScreencopyView can capture them. grim talks to Hyprland's screencopy protocol
# without creating a surface of its own, so the captured PNG still contains the
# original hover state. The QML image backend then presents that already-frozen
# frame. A missing or failed grim falls back to the existing in-overlay capture.
precapture=""
if [ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ] \
	&& [ "${RISHOT_CAPTURE:-}" != screencopy ] \
	&& command -v grim >/dev/null 2>&1; then
	precapture="$rundir/rishot-frozen-$$.png"
	if ! grim "$precapture" || [ ! -s "$precapture" ]; then
		rm -f "$precapture"
		precapture=""
	fi
fi

if [ -n "$precapture" ]; then
	trap 'rm -f "$precapture"' 0
	trap 'exit 1' HUP INT TERM
	env RISHOT_MODE="$mode" RISHOT_CAPTURE=image \
		RISHOT_FROZEN_PNG="$precapture" qs -p "$dir"
else
	exec env RISHOT_MODE="$mode" qs -p "$dir"
fi
